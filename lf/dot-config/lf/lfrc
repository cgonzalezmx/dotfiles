set shell dash
set shellopts '-eu'
set ifs "\n"
set drawbox true
set info size:time

# bookmarks
map gb cd ~/.local/bin
map gc cd ~/.config
map gd cd ~/Descargas
map ge cd /etc
map gi cd ~/Imágenes
map gm cd /run/media/carlos
map gs cd ~/.local/share

# comandos
cmd trash %trash-put $fx; echo 'Movido(s) a papelera'

cmd open ${{
  test -L $f && f=$(readlink -f $f)
  case $(file --mime-type $fx -b) in
    text/*) $EDITOR $fx;;
    application/pdf) zathura $f;;
    *) for f in $fx; do setsid $OPENER $f >/dev/null 2>/dev/null & done;;
  esac
}}

cmd on-redraw %{{
  if [ $lf_width -le 80 ]; then
    lf -remote "send $id set ratios 1:2"
  elif [ $lf_width -le 160 ]; then
    lf -remote "send $id set ratios 1:2:3"
  else
    lf -remote "send $id set ratios 1:2:3:5"
  fi
}}

# atajos
map D trash
map . set hidden!

